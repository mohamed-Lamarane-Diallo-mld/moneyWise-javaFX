<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.project.controller.LoginController"
      styleClass="auth-root"
      stylesheets="@../style/global.css, @../style/auth.css"
      maxWidth="Infinity" maxHeight="Infinity">
    <!-- ═══════════════════════════════ -->
    <!--   PANNEAU GAUCHE — Branding     -->
    <!-- ═══════════════════════════════ -->
    <VBox styleClass="auth-left"
          alignment="CENTER" spacing="20"
          HBox.hgrow="ALWAYS">

        <!-- Logo / Icône -->
        <Label text="💰" style="-fx-font-size: 64px;"/>

        <!-- Nom de l'app -->
        <Label text="MoneyWise" styleClass="auth-brand-title"/>

        <!-- Slogan -->
        <Label text="Votre finances. Votre contrôle."
               styleClass="auth-brand-tagline"/>

        <!-- Description -->
        <Label text="Gérez vos dépenses, suivez vos budgets&#10;et visualisez votre santé financière."
               styleClass="auth-brand-subtitle"
               textAlignment="CENTER" wrapText="true"
               maxWidth="300"/>

        <!-- Séparateur décoratif -->
        <Region prefHeight="20"/>

        <!-- Features rapides -->
        <VBox spacing="12" alignment="CENTER_LEFT" maxWidth="260">
            <Label text="✓  Suivi en temps réel" style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 14px;"/>
            <Label text="✓  Alertes budgétaires" style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 14px;"/>
            <Label text="✓  Export PDF et Excel"  style="-fx-text-fill: rgba(255,255,255,0.85); -fx-font-size: 14px;"/>
        </VBox>
    </VBox>

    <!-- ═══════════════════════════════ -->
    <!--   PANNEAU DROIT — Formulaire    -->
    <!-- ═══════════════════════════════ -->
    <VBox styleClass="auth-right"
          alignment="CENTER" spacing="20"
          prefWidth="480" HBox.hgrow="NEVER">

        <!-- Titre -->
        <Label text="Bon retour !" styleClass="auth-form-title"/>
        <Label text="Connectez-vous à votre espace MoneyWise"
               styleClass="auth-form-subtitle"/>

        <Region prefHeight="10"/>

        <!-- ─── Email ─── -->
        <VBox spacing="6">
            <Label text="Adresse email" styleClass="auth-field-label"/>
            <TextField fx:id="emailField"
                       promptText="exemple@email.com"
                       styleClass="auth-field"/>
        </VBox>

        <!-- ─── Mot de passe ─── -->
        <VBox spacing="6">
            <HBox alignment="CENTER_LEFT">
                <Label text="Mot de passe" styleClass="auth-field-label"
                       HBox.hgrow="ALWAYS"/>
            </HBox>
            <PasswordField fx:id="passwordField"
                           promptText="••••••••"
                           styleClass="auth-field"/>
        </VBox>

        <!-- ─── Message erreur ─── -->
        <Label fx:id="errorLabel" text=""
               styleClass="auth-error"
               wrapText="true" maxWidth="340"
               visible="false" managed="false"/>

        <Region prefHeight="4"/>

        <!-- ─── Bouton Connexion ─── -->
        <Button fx:id="loginBtn"
                text="Se connecter"
                styleClass="auth-btn"
                onAction="#handleLogin"
                defaultButton="true"/>

        <!-- ─── Séparateur ─── -->
        <HBox alignment="CENTER" spacing="0">
            <Separator HBox.hgrow="ALWAYS"/>
            <Label text=" ou " styleClass="auth-divider-label"/>
            <Separator HBox.hgrow="ALWAYS"/>
        </HBox>

        <!-- ─── Lien inscription ─── -->
        <HBox alignment="CENTER" spacing="6">
            <Label text="Pas encore de compte ?"
                   style="-fx-text-fill: #718096; -fx-font-size: 13px;"/>
            <Label text="Créer un compte"
                   styleClass="auth-link"
                   onMouseClicked="#goToInscription"/>
        </HBox>

    </VBox>
</HBox>