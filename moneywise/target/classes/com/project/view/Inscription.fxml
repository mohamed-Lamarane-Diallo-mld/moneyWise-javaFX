<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.project.controller.InscriptionController"
      fx:id="rootPane"
      styleClass="auth-root"
      stylesheets="@../style/global.css, @../style/auth.css"
      maxWidth="Infinity" maxHeight="Infinity">

    <!-- ══ BULLES ══ -->
    <Circle fx:id="bubble1" styleClass="bubble-1"
            radius="55" layoutX="70" layoutY="90" managed="false"/>
    <Circle fx:id="bubble2" styleClass="bubble-2"
            radius="80" layoutX="1080" layoutY="580" managed="false"/>
    <Circle fx:id="bubble3" styleClass="bubble-3"
            radius="45" layoutX="1020" layoutY="160" managed="false"/>
    <Circle fx:id="bubble4" styleClass="bubble-1"
            radius="35" layoutX="120" layoutY="640" managed="false"/>

    <!-- ══ LOGO ══ -->
    <HBox styleClass="auth-header-logo" alignment="CENTER_LEFT" style="-fx-padding:0 0 20 0; -fx-spacing:8;">
        <Label text="MoneyWise" styleClass="auth-logo-text" style="-fx-margin: 10px;" />
    </HBox>

    <!-- ══ FORMULAIRE SCROLLABLE ET CENTRÉ ══ -->
    <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true"
                styleClass="auth-scroll">
        <StackPane alignment="CENTER" minHeight="640">
            <VBox fx:id="formCard" styleClass="auth-form-card"
                  spacing="14" maxWidth="420">

                <!-- Badge étape -->
                <HBox>
                    <Label fx:id="stepIndicator" text="Étape 1 / 2"
                           styleClass="auth-step-badge"/>
                </HBox>

                <!-- Titre dynamique -->
                <VBox spacing="4" alignment="CENTER">
                    <Label fx:id="stepTitle" text="Créer votre compte"
                           styleClass="auth-title"/>
                    <Label fx:id="stepSubtitle"
                           text="Renseignez vos informations personnelles"
                           styleClass="auth-subtitle"/>
                </VBox>

                <!-- Ligne décorative -->
                <Region style="-fx-background-color:linear-gradient(
                               to right,#6C63FF,transparent);
                               -fx-pref-height:2px;
                               -fx-background-radius:2;"
                        maxWidth="70"/>

                <!-- ═ ÉTAPE 1 : Infos personnelles ═ -->
                <VBox fx:id="step1Pane" spacing="12">

                    <VBox spacing="6">
                        <Label text="Nom complet"
                               styleClass="auth-field-label"/>
                        <HBox styleClass="auth-input-wrapper"
                              alignment="CENTER_LEFT" spacing="10">
                            <Label text="👤" style="-fx-font-size:14px;
                                                    -fx-text-fill:#A0AEC0;"/>
                            <TextField fx:id="nomField"
                                       promptText="Votre nom complet"
                                       styleClass="auth-input-field"
                                       HBox.hgrow="ALWAYS"/>
                        </HBox>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="Adresse email"
                               styleClass="auth-field-label"/>
                        <HBox styleClass="auth-input-wrapper"
                              alignment="CENTER_LEFT" spacing="10">
                            <Label text="✉" style="-fx-font-size:14px;
                                                   -fx-text-fill:#A0AEC0;"/>
                            <TextField fx:id="emailField"
                                       promptText="exemple@email.com"
                                       styleClass="auth-input-field"
                                       HBox.hgrow="ALWAYS"/>
                        </HBox>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="Mot de passe"
                               styleClass="auth-field-label"/>
                        <HBox styleClass="auth-input-wrapper"
                              alignment="CENTER_LEFT" spacing="10">
                            <Label text="" style="-fx-font-size:14px;
                                                    -fx-text-fill:#A0AEC0;"/>
                            <PasswordField fx:id="passwordField"
                                           promptText="Minimum 6 caractères"
                                           styleClass="auth-input-field"
                                           HBox.hgrow="ALWAYS"/>
                        </HBox>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="Confirmer le mot de passe"
                               styleClass="auth-field-label"/>
                        <HBox styleClass="auth-input-wrapper"
                              alignment="CENTER_LEFT" spacing="10">
                            <Label text="✓" style="-fx-font-size:14px;
                                                   -fx-text-fill:#A0AEC0;
                                                   -fx-font-weight:bold;"/>
                            <PasswordField fx:id="confirmPasswordField"
                                           promptText="••••••••"
                                           styleClass="auth-input-field"
                                           HBox.hgrow="ALWAYS"/>
                        </HBox>
                    </VBox>

                </VBox>

                <!-- ═ ÉTAPE 2 : Questions sécurité ═ -->
                <VBox fx:id="step2Pane" spacing="10"
                      visible="false" managed="false">

                    <Label text="Ces réponses vous permettront de récupérer votre compte si vous oubliez votre mot de passe."
                           wrapText="true"
                           style="-fx-font-size:12px;
                                  -fx-text-fill:#4A5568;
                                  -fx-background-color:#F0F4FF;
                                  -fx-background-radius:8;
                                  -fx-padding:10 12;
                                  -fx-border-color:#C7D2FE;
                                  -fx-border-radius:8;"/>

                    <!-- Question 1 -->
                    <VBox spacing="5">
                        <Label text="Question 1"
                               styleClass="auth-field-label"/>
                        <ComboBox fx:id="question1Combo"
                                  promptText="Choisir une question…"
                                  styleClass="auth-combo"
                                  maxWidth="Infinity"/>
                        <HBox styleClass="auth-input-wrapper"
                              alignment="CENTER_LEFT" spacing="10">
                            <Label text="💬" style="-fx-font-size:13px;
                                                    -fx-text-fill:#A0AEC0;"/>
                            <TextField fx:id="reponse1Field"
                                       promptText="Votre réponse…"
                                       styleClass="auth-input-field"
                                       HBox.hgrow="ALWAYS"/>
                        </HBox>
                    </VBox>

                    <!-- Question 2 -->
                    <VBox spacing="5">
                        <Label text="Question 2"
                               styleClass="auth-field-label"/>
                        <ComboBox fx:id="question2Combo"
                                  promptText="Choisir une question…"
                                  styleClass="auth-combo"
                                  maxWidth="Infinity"/>
                        <HBox styleClass="auth-input-wrapper"
                              alignment="CENTER_LEFT" spacing="10">
                            <Label text="" style="-fx-font-size:13px;
                                                    -fx-text-fill:#A0AEC0;"/>
                            <TextField fx:id="reponse2Field"
                                       promptText="Votre réponse…"
                                       styleClass="auth-input-field"
                                       HBox.hgrow="ALWAYS"/>
                        </HBox>
                    </VBox>

                    <!-- Question 3 -->
                    <VBox spacing="5">
                        <Label text="Question 3"
                               styleClass="auth-field-label"/>
                        <ComboBox fx:id="question3Combo"
                                  promptText="Choisir une question…"
                                  styleClass="auth-combo"
                                  maxWidth="Infinity"/>
                        <HBox styleClass="auth-input-wrapper"
                              alignment="CENTER_LEFT" spacing="10">
                            <Label text="" style="-fx-font-size:13px;
                                                    -fx-text-fill:#A0AEC0;"/>
                            <TextField fx:id="reponse3Field"
                                       promptText="Votre réponse…"
                                       styleClass="auth-input-field"
                                       HBox.hgrow="ALWAYS"/>
                        </HBox>
                    </VBox>

                </VBox>

                <!-- Messages -->
                <HBox fx:id="errorBox" spacing="8" alignment="CENTER_LEFT"
                      styleClass="auth-error-box"
                      visible="false" managed="false">
                    <Label text="⚠" style="-fx-font-size:14px;
                                           -fx-text-fill:#E74C3C;"/>
                    <Label fx:id="errorLabel" text=""
                           style="-fx-text-fill:#C53030; -fx-font-size:12px;"
                           wrapText="true" HBox.hgrow="ALWAYS"/>
                </HBox>

                <HBox fx:id="successBox" spacing="8" alignment="CENTER_LEFT"
                      styleClass="auth-success-box"
                      visible="false" managed="false">
                    <Label text="✓" style="-fx-font-size:14px;
                                          -fx-text-fill:#2ECC71;
                                          -fx-font-weight:bold;"/>
                    <Label fx:id="successLabel" text=""
                           style="-fx-text-fill:#276749; -fx-font-size:12px;"
                           wrapText="true" HBox.hgrow="ALWAYS"/>
                </HBox>

                <!-- Boutons -->
                <VBox spacing="10">
                    <!-- Étape 1 -->
                    <Button fx:id="btnSuivant"
                            text="Suivant  →"
                            styleClass="auth-btn"
                            onAction="#handleSuivant"
                            maxWidth="Infinity"/>
                    <!-- Étape 2 -->
                    <HBox spacing="10">
                        <Button fx:id="btnPrecedent"
                                text="← Retour"
                                styleClass="auth-btn-back"
                                onAction="#handlePrecedent"
                                visible="false" managed="false"
                                prefWidth="110"/>
                        <Button fx:id="inscriptionBtn"
                                text="Créer mon compte  →"
                                styleClass="auth-btn"
                                onAction="#handleInscription"
                                defaultButton="true"
                                visible="false" managed="false"
                                HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>

                <!-- Séparateur -->
                <HBox alignment="CENTER" spacing="0"
                      style="-fx-padding:2 0;">
                    <Separator HBox.hgrow="ALWAYS"
                               style="-fx-opacity:0.3;"/>
                    <Label text="  ou  "
                           style="-fx-text-fill:#A0AEC0;
                                  -fx-font-size:12px;"/>
                    <Separator HBox.hgrow="ALWAYS"
                               style="-fx-opacity:0.3;"/>
                </HBox>

                <!-- Lien login -->
                <HBox alignment="CENTER" spacing="6">
                    <Label text="Déjà un compte ?"
                           style="-fx-text-fill:#718096;
                                  -fx-font-size:13px;"/>
                    <Label text="Se connecter"
                           styleClass="auth-link"
                           onMouseClicked="#goToLogin"/>
                </HBox>

            </VBox>
        </StackPane>
    </ScrollPane>
</VBox>