<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.project.controller.AdminUtilisateursController"
      styleClass="home-root"
      stylesheets="@../style/global.css, @../style/sidebar.css,
                   @../style/home.css, @../style/transaction.css"
      maxWidth="Infinity" maxHeight="Infinity">

    <fx:include fx:id="sidebar" source="Sidebar.fxml"/>

    <VBox HBox.hgrow="ALWAYS">

        <HBox styleClass="header" alignment="CENTER_LEFT" spacing="0">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Gestion des utilisateurs" styleClass="header-title"/>
                <Label fx:id="headerDate" text="" styleClass="header-date"/>
            </VBox>
            <HBox spacing="14" alignment="CENTER">
                <VBox alignment="CENTER" spacing="2"
                      style="-fx-background-color:#EAE8FF;-fx-background-radius:10;-fx-padding:8 18;">
                    <Label text="UTILISATEURS"
                           style="-fx-font-size:9px;-fx-font-weight:bold;-fx-text-fill:#6C63FF;"/>
                    <Label fx:id="headerTotalUsers" text="— comptes"
                           style="-fx-font-size:15px;-fx-font-weight:bold;-fx-text-fill:#4338CA;"/>
                </VBox>
            </HBox>
        </HBox>

        <Region prefHeight="2"
                style="-fx-background-color:linear-gradient(to right,#6C63FF 0%,#2ECC71 50%,transparent 100%);-fx-opacity:0.5;"/>

        <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" styleClass="scroll-pane">
            <VBox styleClass="home-content" spacing="22">

                <VBox spacing="2">
                    <Label text="Administration des utilisateurs" styleClass="section-title"/>
                    <Label text="Gérer les comptes, rôles et statuts des utilisateurs de l'application"
                           styleClass="section-subtitle"/>
                </VBox>

                <!-- KPI -->
                <HBox spacing="16">
                    <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS" spacing="0">
                        <HBox alignment="CENTER_LEFT" spacing="0">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <Label text="U" styleClass="kpi-badge-green"/>
                                    <Label text="TOTAL UTILISATEURS" styleClass="kpi-label"/>
                                </HBox>
                                <Label fx:id="totalUtilisateurs" text="0" styleClass="kpi-value, kpi-value-green"/>
                                <Label text="comptes enregistrés" styleClass="kpi-evolution"/>
                            </VBox>
                            <StackPane styleClass="kpi-icon-box, kpi-icon-box-green">
                                <Label text=" " styleClass="kpi-icon"/>
                            </StackPane>
                        </HBox>
                        <Region prefHeight="14"/>
                        <Region styleClass="kpi-bar-green" maxWidth="56"/>
                    </VBox>
                    <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS" spacing="0">
                        <HBox alignment="CENTER_LEFT" spacing="0">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <Label text="A" styleClass="kpi-badge-purple"/>
                                    <Label text="ADMINISTRATEURS" styleClass="kpi-label"/>
                                </HBox>
                                <Label fx:id="totalAdmins" text="0" styleClass="kpi-value"/>
                                <Label text="avec droits admin" styleClass="kpi-evolution"/>
                            </VBox>
                            <StackPane styleClass="kpi-icon-box" style="-fx-background-color:#EAE8FF;">
                                <Label text=" " styleClass="kpi-icon"/>
                            </StackPane>
                        </HBox>
                        <Region prefHeight="14"/>
                        <Region style="-fx-background-color:#6C63FF;-fx-background-radius:2;-fx-pref-height:3;" maxWidth="56"/>
                    </VBox>
                    <VBox styleClass="kpi-card-purple" HBox.hgrow="ALWAYS" spacing="0">
                        <HBox alignment="CENTER_LEFT" spacing="0">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <Label text="I" styleClass="kpi-badge-white"/>
                                    <Label text="INACTIFS" styleClass="kpi-label-white"/>
                                </HBox>
                                <Label fx:id="totalInactifs" text="0" styleClass="kpi-value, kpi-value-white"/>
                                <Label text="comptes désactivés" styleClass="kpi-evolution-white"/>
                            </VBox>
                            <StackPane styleClass="kpi-icon-box, kpi-icon-box-purple">
                                <Label text=" " styleClass="kpi-icon"/>
                            </StackPane>
                        </HBox>
                        <Region prefHeight="14"/>
                        <Region styleClass="kpi-bar-white" maxWidth="56"/>
                    </VBox>
                    <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS" spacing="0">
                        <HBox alignment="CENTER_LEFT" spacing="0">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <Label text="N" styleClass="kpi-badge-red"/>
                                    <Label text="NOUVEAUX CE MOIS" styleClass="kpi-label"/>
                                </HBox>
                                <Label fx:id="totalNouveauxMois" text="0" styleClass="kpi-value, kpi-value-red"/>
                                <Label text="inscriptions récentes" styleClass="kpi-evolution"/>
                            </VBox>
                            <StackPane styleClass="kpi-icon-box, kpi-icon-box-red">
                                <Label text=" " styleClass="kpi-icon"/>
                            </StackPane>
                        </HBox>
                        <Region prefHeight="14"/>
                        <Region styleClass="kpi-bar-red" maxWidth="56"/>
                    </VBox>
                </HBox>

                <!-- FILTRES -->
                <VBox styleClass="table-card" spacing="0">
                    <HBox styleClass="table-header-zone" alignment="CENTER_LEFT">
                        <Label text="Filtrer les utilisateurs" styleClass="section-title" HBox.hgrow="ALWAYS"/>
                        <Button text="✕ Réinitialiser" styleClass="btn-voir-tout"
                                style="-fx-font-size:11px;-fx-padding:5 12;" onAction="#resetFiltres"/>
                    </HBox>
                    <Separator style="-fx-opacity:0.4;"/>
                    <HBox style="-fx-padding:12 18;" spacing="10" alignment="CENTER_LEFT">
                        <HBox alignment="CENTER_LEFT" spacing="0"
                              style="-fx-background-color:#F7FAFC;-fx-border-color:#E2E8F0;-fx-border-radius:8;-fx-background-radius:8;">
                            <Label text=" 🔍 " style="-fx-font-size:12px;-fx-text-fill:#94A3B8;"/>
                            <TextField fx:id="searchField" promptText="Rechercher par nom ou email..."
                                       style="-fx-background-color:transparent;-fx-border-color:transparent;-fx-padding:7 10 7 0;-fx-font-size:12px;"
                                       prefWidth="240" onKeyReleased="#onSearchChanged"/>
                        </HBox>
                        <ComboBox fx:id="filterStatut" promptText="Statut"
                                  style="-fx-background-color:#F7FAFC;-fx-border-color:#E2E8F0;-fx-border-radius:8;-fx-background-radius:8;-fx-font-size:12px;"
                                  prefWidth="130" onAction="#onFilterChanged"/>
                        <ComboBox fx:id="filterRole" promptText="Rôle"
                                  style="-fx-background-color:#F7FAFC;-fx-border-color:#E2E8F0;-fx-border-radius:8;-fx-background-radius:8;-fx-font-size:12px;"
                                  prefWidth="140" onAction="#onFilterChanged"/>
                    </HBox>
                </VBox>

                <!-- TABLE -->
                <VBox styleClass="table-card" spacing="0">
                    <HBox styleClass="table-header-zone" alignment="CENTER_LEFT">
                        <VBox HBox.hgrow="ALWAYS" spacing="2">
                            <Label text="Liste des utilisateurs" styleClass="section-title"/>
                            <Label fx:id="countLabel" text="0 utilisateur(s)" styleClass="section-subtitle"/>
                        </VBox>
                    </HBox>
                    <Separator style="-fx-opacity:0.5;"/>

                    <TableView fx:id="utilisateursTable"
                               styleClass="table-view"
                               prefHeight="440"
                               VBox.vgrow="ALWAYS"
                               style="-fx-background-color:transparent;
                                      -fx-border-color:transparent;
                                      -fx-table-cell-border-color:transparent;">
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                        <columns>
                            <TableColumn fx:id="colId"              text="ID"           minWidth="60"  maxWidth="60"/>
                            <TableColumn fx:id="colNom"             text="NOM"          minWidth="90"/>
                            <TableColumn fx:id="colEmail"           text="EMAIL"        minWidth="90"/>
                            <TableColumn fx:id="colDateInscription" text="INSCRIPTION"  minWidth="100" maxWidth="115"/>
                            <TableColumn fx:id="colStatut"          text="STATUT"       minWidth="60"  maxWidth="95"/>
                            <TableColumn fx:id="colRole"            text="RÔLE"         minWidth="90"  maxWidth="100"/>
                            <TableColumn fx:id="colActions"         text="ACTIONS"      minWidth="300" maxWidth="400"/>
                        </columns>
                        <placeholder>
                            <VBox alignment="CENTER" spacing="8" style="-fx-padding:50;">
                                <Label text="👤" style="-fx-font-size:36px;"/>
                                <Label text="Aucun utilisateur trouvé"
                                       style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#64748B;"/>
                                <Label text="Modifiez les filtres pour afficher des résultats."
                                       style="-fx-font-size:12px;-fx-text-fill:#94A3B8;"/>
                            </VBox>
                        </placeholder>
                    </TableView>

                    <!-- PAGINATION -->
                    <HBox alignment="CENTER" spacing="8"
                          style="-fx-padding:10 18;-fx-background-color:#FAFBFF;
                                 -fx-border-color:#F0F0F0 transparent transparent transparent;">
                        <Label fx:id="paginationInfo" text=""
                               style="-fx-font-size:11px;-fx-text-fill:#718096;" HBox.hgrow="ALWAYS"/>
                        <HBox spacing="5" alignment="CENTER">
                            <Button fx:id="btnPremierePage" text="«" onAction="#goToPremierePage"
                                    styleClass="btn-voir-tout" style="-fx-min-width:32px;-fx-font-weight:bold;"/>
                            <Button fx:id="btnPagePrev" text="‹ Préc." onAction="#goToPagePrecedente" styleClass="btn-voir-tout"/>
                            <HBox fx:id="pageNumbersBox" spacing="4" alignment="CENTER"/>
                            <Button fx:id="btnPageNext" text="Suiv. ›" onAction="#goToPageSuivante" styleClass="btn-voir-tout"/>
                            <Button fx:id="btnDernierePage" text="»" onAction="#goToDernierePage"
                                    styleClass="btn-voir-tout" style="-fx-min-width:32px;-fx-font-weight:bold;"/>
                        </HBox>
                        <HBox spacing="6" alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                            <Label text="Par page :" style="-fx-font-size:11px;-fx-text-fill:#718096;"/>
                            <ComboBox fx:id="pageSizeCombo" prefWidth="65" onAction="#onPageSizeChanged"
                                      style="-fx-background-color:#F7FAFC;-fx-border-color:#E2E8F0;-fx-border-radius:8;-fx-background-radius:8;-fx-font-size:12px;"/>
                        </HBox>
                    </HBox>
                </VBox>

            </VBox>
        </ScrollPane>
    </VBox>
</HBox>