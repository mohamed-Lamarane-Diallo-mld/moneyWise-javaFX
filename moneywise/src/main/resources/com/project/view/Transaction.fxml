<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.project.controller.TransactionController"
      styleClass="transaction-root"
      stylesheets="@../style/global.css, @../style/sidebar.css,
                   @../style/home.css, @../style/transaction.css"
      maxWidth="Infinity" maxHeight="Infinity">

    <fx:include fx:id="sidebar" source="Sidebar.fxml"/>

    <VBox HBox.hgrow="ALWAYS">

        <!-- ══════════════════════════════════ -->
        <!-- HEADER — cohérent avec Home        -->
        <!-- ══════════════════════════════════ -->
        <HBox styleClass="header" alignment="CENTER_LEFT" spacing="0">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label fx:id="headerUser" text="Transactions"
                       styleClass="header-title"/>
                <Label fx:id="headerDate" text=""
                       styleClass="header-date"/>
            </VBox>

            <HBox spacing="14" alignment="CENTER">
                <!-- Solde rapide -->
                <VBox alignment="CENTER" spacing="2"
                      style="-fx-background-color:#F0FFF4;
                             -fx-background-radius:10;
                             -fx-padding:8 18;">
                    <Label text="SOLDE"
                           style="-fx-font-size:9px; -fx-font-weight:bold;
                                  -fx-text-fill:#38A169;"/>
                    <Label fx:id="soldeLabel" text="— FCFA"
                           style="-fx-font-size:15px; -fx-font-weight:bold;
                                  -fx-text-fill:#276749;"/>
                </VBox>

                <Button text="＋ Nouvelle transaction"
                        onAction="#openModalAjouter"
                        style="-fx-background-color:#6C63FF;
                               -fx-text-fill:white;
                               -fx-font-size:13px;
                               -fx-font-weight:bold;
                               -fx-padding:10 20;
                               -fx-background-radius:9;
                               -fx-cursor:hand;"/>
            </HBox>
        </HBox>

        <!-- Ligne décorative -->
       <Region prefHeight="2"
                style="-fx-background-color:linear-gradient(to right,
                       #6C63FF 0%, #2ECC71 50%, transparent 100%);
                       -fx-opacity:0.5;"/>

        <!-- SCROLL PRINCIPAL -->
        <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true"
                    styleClass="scroll-pane">
            <VBox styleClass="home-content" spacing="22">

                <!-- TITRE -->
                <VBox spacing="2">
                    <Label text="Gestion des transactions"
                           styleClass="section-title"/>
                    <Label text="Suivi complet de vos entrées et sorties financières"
                           styleClass="section-subtitle"/>
                </VBox>

                <!-- ══════════════════════════════════ -->
                <!-- KPI CARDS                          -->
                <!-- ══════════════════════════════════ -->
                <HBox spacing="16">

                    <!-- ENTRÉES -->
                    <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS" spacing="0">
                        <HBox alignment="CENTER_LEFT" spacing="0">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <Label text="↑" styleClass="kpi-badge-green"/>
                                    <Label text="ENTRÉES DU MOIS"
                                           styleClass="kpi-label"/>
                                </HBox>
                                <Label fx:id="resumeEntrees" text="0 FCFA"
                                       styleClass="kpi-value, kpi-value-green"/>
                                <Label text="" styleClass="kpi-evolution"/>
                            </VBox>
                            <StackPane styleClass="kpi-icon-box, kpi-icon-box-green">
                                <Label text="" styleClass="kpi-icon"/>
                            </StackPane>
                        </HBox>
                        <Region prefHeight="14"/>
                        <Region styleClass="kpi-bar-green" maxWidth="56"/>
                    </VBox>

                    <!-- SORTIES -->
                    <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS" spacing="0">
                        <HBox alignment="CENTER_LEFT" spacing="0">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <Label text="↓" styleClass="kpi-badge-red"/>
                                    <Label text="SORTIES DU MOIS"
                                           styleClass="kpi-label"/>
                                </HBox>
                                <Label fx:id="resumeSorties" text="0 FCFA"
                                       styleClass="kpi-value, kpi-value-red"/>
                                <Label text="" styleClass="kpi-evolution"/>
                            </VBox>
                            <StackPane styleClass="kpi-icon-box, kpi-icon-box-red">
                                <Label text="💸" styleClass="kpi-icon"/>
                            </StackPane>
                        </HBox>
                        <Region prefHeight="14"/>
                        <Region styleClass="kpi-bar-red" maxWidth="56"/>
                    </VBox>

                    <!-- ÉPARGNE -->
                    <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS" spacing="0">
                        <HBox alignment="CENTER_LEFT" spacing="0">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <Label text="◈" styleClass="kpi-badge-white"
                                           style="-fx-background-color:#EAE8FF;
                                                  -fx-text-fill:#6C63FF;
                                                  -fx-font-size:11px;
                                                  -fx-font-weight:bold;
                                                  -fx-padding:3 8;
                                                  -fx-background-radius:6;"/>
                                    <Label text="ÉPARGNE DU MOIS"
                                           styleClass="kpi-label"/>
                                </HBox>
                                <Label fx:id="resumeEpargne" text="0 FCFA"
                                       styleClass="kpi-value"
                                       style="-fx-text-fill:#6C63FF;
                                              -fx-font-size:26px;
                                              -fx-font-weight:bold;"/>
                                <Label text="" styleClass="kpi-evolution"/>
                            </VBox>
                            <StackPane styleClass="kpi-icon-box, kpi-icon-box-purple">
                                <Label text="🏦" styleClass="kpi-icon"/>
                            </StackPane>
                        </HBox>
                        <Region prefHeight="14"/>
                        <Region style="-fx-background-color:#6C63FF;
                                       -fx-background-radius:2;
                                       -fx-pref-height:3;" maxWidth="56"/>
                    </VBox>

                    <!-- NB TRANSACTIONS -->
                    <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS" spacing="0">
                        <HBox alignment="CENTER_LEFT" spacing="0">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <Label text="#"
                                           style="-fx-background-color:#E8F8F1;
                                                  -fx-text-fill:#27AE60;
                                                  -fx-font-size:11px;
                                                  -fx-font-weight:bold;
                                                  -fx-padding:3 8;
                                                  -fx-background-radius:6;"/>
                                    <Label text="TRANSACTIONS" styleClass="kpi-label"/>
                                </HBox>
                                <Label fx:id="resumeNbTrans" text="0"
                                       styleClass="kpi-value"/>
                                <Label text="au total" styleClass="kpi-evolution"/>
                            </VBox>
                            <StackPane styleClass="kpi-icon-box"
                                       style="-fx-background-color:#E8F8F1;">
                                <Label text="📋" styleClass="kpi-icon"/>
                            </StackPane>
                        </HBox>
                        <Region prefHeight="14"/>
                        <Region style="-fx-background-color:#27AE60;
                                       -fx-background-radius:2;
                                       -fx-pref-height:3;" maxWidth="56"/>
                    </VBox>

                </HBox>

                <!-- ══════════════════════════════════ -->
                <!-- BUDGETS + CATÉGORIES               -->
                <!-- ══════════════════════════════════ -->
                <HBox spacing="20" alignment="TOP_LEFT">

                    <!-- BUDGETS -->
                    <VBox styleClass="table-card" spacing="0"
                          HBox.hgrow="ALWAYS"
                          prefHeight="340" maxHeight="340" minHeight="340">

                        <HBox alignment="CENTER_LEFT"
                              style="-fx-padding:16 18 14 18;">
                            <VBox HBox.hgrow="ALWAYS" spacing="2">
                                <Label text="Budgets du mois"
                                       styleClass="section-title"/>
                                <Label text="Suivi de vos plafonds"
                                       styleClass="section-subtitle"/>
                            </VBox>
                            <Button text="＋ Ajouter"
                                    styleClass="quick-btn-primary"
                                    style="-fx-font-size:12px; -fx-padding:7 14;"
                                    onAction="#openModalAjouterBudget"/>
                        </HBox>

                        <Separator/>

                        <!-- Total budgété + œil -->
                        <HBox alignment="CENTER_LEFT" spacing="8"
                              style="-fx-padding:8 18 6 18;
                                     -fx-background-color:#FAFBFF;">
                            <Label text="Total budgété :"
                                   style="-fx-font-size:12px;
                                          -fx-text-fill:#718096;
                                          -fx-font-weight:bold;"/>
                            <Label fx:id="totalBudgetLabel" text="—"
                                   style="-fx-font-size:13px;
                                          -fx-font-weight:bold;
                                          -fx-text-fill:#6C63FF;"/>
                            <Button fx:id="toggleBudgetBtn" text="👁"
                                    onAction="#toggleBudgetVisible"
                                    style="-fx-background-color:transparent;
                                           -fx-font-size:14px;
                                           -fx-cursor:hand;
                                           -fx-padding:2 6;
                                           -fx-border-color:transparent;"/>
                        </HBox>

                        <Separator style="-fx-opacity:0.3;"/>

                        <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true"
                                    style="-fx-background-color:transparent;
                                           -fx-border-color:transparent;
                                           -fx-padding:0;">
                            <VBox>
                                <VBox fx:id="budgetListContainer" spacing="14"
                                      style="-fx-padding:12 16;"/>
                                <Label fx:id="noBudgetLabel"
                                       text="Aucun budget ce mois.&#10;Cliquez sur ＋ pour en créer un."
                                       style="-fx-text-fill:#A0AEC0;
                                              -fx-font-size:13px;
                                              -fx-padding:20;
                                              -fx-text-alignment:center;"
                                       textAlignment="CENTER" wrapText="true"
                                       visible="false" managed="false"/>
                            </VBox>
                        </ScrollPane>

                        <HBox fx:id="budgetPaginationBox"
                              alignment="CENTER" spacing="10"
                              style="-fx-padding:6 16 10 16;
                                     -fx-background-color:white;
                                     -fx-border-color:#F0F0F0 transparent
                                                      transparent transparent;"
                              visible="false" managed="false">
                            <Button fx:id="budgetPrevBtn" text="‹"
                                    onAction="#budgetPagePrev"
                                    style="-fx-background-color:#F7FAFC;
                                           -fx-border-color:#E2E8F0;
                                           -fx-border-radius:6;
                                           -fx-background-radius:6;
                                           -fx-cursor:hand;
                                           -fx-padding:4 12;
                                           -fx-font-size:14px;"/>
                            <Label fx:id="budgetPageLabel" text="1 / 1"
                                   style="-fx-font-size:12px;
                                          -fx-text-fill:#718096;
                                          -fx-min-width:40px;
                                          -fx-alignment:center;"/>
                            <Button fx:id="budgetNextBtn" text="›"
                                    onAction="#budgetPageNext"
                                    style="-fx-background-color:#F7FAFC;
                                           -fx-border-color:#E2E8F0;
                                           -fx-border-radius:6;
                                           -fx-background-radius:6;
                                           -fx-cursor:hand;
                                           -fx-padding:4 12;
                                           -fx-font-size:14px;"/>
                        </HBox>

                    </VBox>

                    <!-- CATÉGORIES -->
                    <VBox styleClass="table-card" spacing="0"
                          prefWidth="300" minWidth="300" maxWidth="300"
                          prefHeight="340" maxHeight="340" minHeight="340">

                        <HBox alignment="CENTER_LEFT"
                              style="-fx-padding:16 18 14 18;">
                            <VBox HBox.hgrow="ALWAYS" spacing="2">
                                <Label text="Mes catégories"
                                       styleClass="section-title"/>
                                <Label text="Catégories personnalisées"
                                       styleClass="section-subtitle"/>
                            </VBox>
                            <Button text="＋ Ajouter"
                                    styleClass="quick-btn-primary"
                                    style="-fx-font-size:12px; -fx-padding:7 14;"
                                    onAction="#openModalAjouterCategorie"/>
                        </HBox>

                        <Separator/>

                        <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true"
                                    style="-fx-background-color:transparent;
                                           -fx-border-color:transparent;
                                           -fx-padding:0;">
                            <VBox>
                                <VBox fx:id="categorieListContainer" spacing="6"
                                      style="-fx-padding:12 16;"/>
                                <Label fx:id="noCategorieLabel"
                                       text="Aucune catégorie personnalisée."
                                       style="-fx-text-fill:#A0AEC0;
                                              -fx-font-size:13px;
                                              -fx-padding:20;"
                                       visible="false" managed="false"/>
                            </VBox>
                        </ScrollPane>

                        <HBox fx:id="categoriePaginationBox"
                              alignment="CENTER" spacing="10"
                              style="-fx-padding:6 16 10 16;
                                     -fx-background-color:white;
                                     -fx-border-color:#F0F0F0 transparent
                                                      transparent transparent;"
                              visible="false" managed="false">
                            <Button fx:id="categoriePrevBtn" text="‹"
                                    onAction="#categoriePagePrev"
                                    style="-fx-background-color:#F7FAFC;
                                           -fx-border-color:#E2E8F0;
                                           -fx-border-radius:6;
                                           -fx-background-radius:6;
                                           -fx-cursor:hand;
                                           -fx-padding:4 12;
                                           -fx-font-size:14px;"/>
                            <Label fx:id="categoriePageLabel" text="1 / 1"
                                   style="-fx-font-size:12px;
                                          -fx-text-fill:#718096;
                                          -fx-min-width:40px;
                                          -fx-alignment:center;"/>
                            <Button fx:id="categorieNextBtn" text="›"
                                    onAction="#categoriePageNext"
                                    style="-fx-background-color:#F7FAFC;
                                           -fx-border-color:#E2E8F0;
                                           -fx-border-radius:6;
                                           -fx-background-radius:6;
                                           -fx-cursor:hand;
                                           -fx-padding:4 12;
                                           -fx-font-size:14px;"/>
                        </HBox>

                    </VBox>

                </HBox>

                <!-- ══════════════════════════════════ -->
                <!-- FILTRES                            -->
                <!-- ══════════════════════════════════ -->
                <VBox styleClass="table-card" spacing="0">

                    <HBox alignment="CENTER_LEFT"
                          style="-fx-padding:14 18 12 18;">
                        <Label text="Filtrer les transactions"
                               styleClass="section-title"
                               HBox.hgrow="ALWAYS"/>
                        <Button text="✕ Réinitialiser"
                                styleClass="quick-btn-secondary"
                                style="-fx-font-size:12px; -fx-padding:7 14;"
                                onAction="#onResetFilters"/>
                    </HBox>

                    <Separator style="-fx-opacity:0.4;"/>

                    <HBox style="-fx-padding:14 18;" spacing="12"
                          alignment="CENTER_LEFT">

                        <TextField fx:id="searchField"
                                   promptText="Rechercher..."
                                   style="-fx-background-color:#F7FAFC;
                                          -fx-border-color:#E2E8F0;
                                          -fx-border-radius:8;
                                          -fx-background-radius:8;
                                          -fx-padding:9 14;
                                          -fx-font-size:13px;"
                                   prefWidth="200"
                                   onKeyReleased="#onSearchChanged"/>

                        <ComboBox fx:id="filterType"
                                  promptText="Type"
                                  style="-fx-background-color:#F7FAFC;
                                         -fx-border-color:#E2E8F0;
                                         -fx-border-radius:8;
                                         -fx-background-radius:8;
                                         -fx-font-size:13px;"
                                  prefWidth="130"
                                  onAction="#onFilterChanged"/>

                        <ComboBox fx:id="filterCategorie"
                                  promptText="Catégorie"
                                  style="-fx-background-color:#F7FAFC;
                                         -fx-border-color:#E2E8F0;
                                         -fx-border-radius:8;
                                         -fx-background-radius:8;
                                         -fx-font-size:13px;"
                                  prefWidth="160"
                                  onAction="#onFilterChanged"/>

                        <DatePicker fx:id="filterDateDebut"
                                    promptText="Date début"
                                    style="-fx-background-color:#F7FAFC;
                                           -fx-border-color:#E2E8F0;
                                           -fx-border-radius:8;
                                           -fx-background-radius:8;
                                           -fx-font-size:13px;"
                                    onAction="#onFilterChanged"/>

                        <DatePicker fx:id="filterDateFin"
                                    promptText="Date fin"
                                    style="-fx-background-color:#F7FAFC;
                                           -fx-border-color:#E2E8F0;
                                           -fx-border-radius:8;
                                           -fx-background-radius:8;
                                           -fx-font-size:13px;"
                                    onAction="#onFilterChanged"/>

                    </HBox>
                </VBox>

                <!-- ══════════════════════════════════ -->
                <!-- TABLE TRANSACTIONS PAGINÉE         -->
                <!-- ══════════════════════════════════ -->
                <VBox styleClass="table-card" spacing="0">

                    <!-- En-tête table -->
                    <HBox alignment="CENTER_LEFT"
                          style="-fx-padding:16 18 14 18;">
                        <VBox HBox.hgrow="ALWAYS" spacing="2">
                            <Label text="Liste des transactions"
                                   styleClass="section-title"/>
                            <Label fx:id="countLabel" text="0 transaction(s)"
                                   styleClass="section-subtitle"/>
                        </VBox>
                        <Button text="＋  Nouvelle transaction"
                                onAction="#openModalAjouter"
                                style="-fx-background-color:#6C63FF;
                                       -fx-text-fill:white;
                                       -fx-font-size:13px;
                                       -fx-font-weight:bold;
                                       -fx-padding:10 18;
                                       -fx-background-radius:9;
                                       -fx-cursor:hand;"/>
                    </HBox>

                    <Separator style="-fx-opacity:0.5;"/>

                    <!-- TableView -->
                    <TableView fx:id="transactionsTable"
                               styleClass="table-view"
                               prefHeight="380"
                               VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colDate"
                                         text="DATE" prefWidth="120"/>
                            <TableColumn fx:id="colDescription"
                                         text="DESCRIPTION" prefWidth="220"/>
                            <TableColumn fx:id="colCategorie"
                                         text="CATÉGORIE" prefWidth="140"/>
                            <TableColumn fx:id="colType"
                                         text="TYPE" prefWidth="100"/>
                            <TableColumn fx:id="colMontant"
                                         text="MONTANT" prefWidth="140"/>
                            <TableColumn fx:id="colActions"
                                         text="ACTIONS" prefWidth="180"/>
                        </columns>
                    </TableView>

                    <!-- ✅ PAGINATION TABLE -->
                    <HBox alignment="CENTER" spacing="8"
                          style="-fx-padding:14 18;
                                 -fx-background-color:#FAFBFF;
                                 -fx-border-color:#F0F0F0 transparent
                                                  transparent transparent;">

                        <!-- Info résumé gauche -->
                        <Label fx:id="paginationInfo" text=""
                               style="-fx-font-size:12px; -fx-text-fill:#718096;"
                               HBox.hgrow="ALWAYS"/>

                        <!-- Boutons pagination -->
                        <HBox spacing="6" alignment="CENTER">

                            <!-- Première page -->
                            <Button fx:id="btnPremierePage" text="«"
                                    onAction="#goToPremierePage"
                                    style="-fx-background-color:#F7FAFC;
                                           -fx-border-color:#E2E8F0;
                                           -fx-border-radius:8;
                                           -fx-background-radius:8;
                                           -fx-cursor:hand;
                                           -fx-padding:8 12;
                                           -fx-font-size:13px;"/>

                            <!-- Page précédente -->
                            <Button fx:id="btnPagePrev" text="‹  Précédent"
                                    onAction="#goToPagePrecedente"
                                    style="-fx-background-color:#F7FAFC;
                                           -fx-border-color:#E2E8F0;
                                           -fx-border-radius:8;
                                           -fx-background-radius:8;
                                           -fx-cursor:hand;
                                           -fx-padding:8 14;
                                           -fx-font-size:13px;"/>

                            <!-- Numéros de pages -->
                            <HBox fx:id="pageNumbersBox" spacing="4"
                                  alignment="CENTER"/>

                            <!-- Page suivante -->
                            <Button fx:id="btnPageNext" text="Suivant  ›"
                                    onAction="#goToPageSuivante"
                                    style="-fx-background-color:#F7FAFC;
                                           -fx-border-color:#E2E8F0;
                                           -fx-border-radius:8;
                                           -fx-background-radius:8;
                                           -fx-cursor:hand;
                                           -fx-padding:8 14;
                                           -fx-font-size:13px;"/>

                            <!-- Dernière page -->
                            <Button fx:id="btnDernierePage" text="»"
                                    onAction="#goToDernierePage"
                                    style="-fx-background-color:#F7FAFC;
                                           -fx-border-color:#E2E8F0;
                                           -fx-border-radius:8;
                                           -fx-background-radius:8;
                                           -fx-cursor:hand;
                                           -fx-padding:8 12;
                                           -fx-font-size:13px;"/>
                        </HBox>

                        <!-- Sélecteur nb par page -->
                        <HBox spacing="8" alignment="CENTER"
                              HBox.hgrow="ALWAYS"
                              style="-fx-alignment:CENTER_RIGHT;">
                            <Label text="Par page :"
                                   style="-fx-font-size:12px;
                                          -fx-text-fill:#718096;"/>
                            <ComboBox fx:id="pageSizeCombo"
                                      style="-fx-background-color:#F7FAFC;
                                             -fx-border-color:#E2E8F0;
                                             -fx-border-radius:8;
                                             -fx-background-radius:8;
                                             -fx-font-size:12px;"
                                      prefWidth="70"
                                      onAction="#onPageSizeChanged"/>
                        </HBox>

                    </HBox>

                </VBox>

            </VBox>
        </ScrollPane>
    </VBox>
</HBox>