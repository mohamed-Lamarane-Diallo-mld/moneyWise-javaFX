<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.project.controller.AdminLogsController"
      styleClass="home-root"
      stylesheets="@../style/global.css, @../style/sidebar.css,
                   @../style/home.css, @../style/transaction.css"
      maxWidth="Infinity" maxHeight="Infinity">

    <fx:include fx:id="sidebar" source="Sidebar.fxml"/>

    <VBox HBox.hgrow="ALWAYS">

        <HBox styleClass="header" alignment="CENTER_LEFT" spacing="0">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Journal d'activité" styleClass="header-title"/>
                <Label fx:id="headerDate" text="" styleClass="header-date"/>
            </VBox>
            <HBox spacing="14" alignment="CENTER">
                <VBox alignment="CENTER" spacing="2"
                      style="-fx-background-color:#FEF3C7;-fx-background-radius:10;-fx-padding:8 18;">
                    <Label text="ACTIONS"
                           style="-fx-font-size:9px;-fx-font-weight:bold;-fx-text-fill:#D97706;"/>
                    <Label fx:id="headerTotalLogs" text="— enregistrées"
                           style="-fx-font-size:15px;-fx-font-weight:bold;-fx-text-fill:#92400E;"/>
                </VBox>
            </HBox>
        </HBox>

        <Region prefHeight="2"
                style="-fx-background-color:linear-gradient(to right,#6C63FF 0%,#2ECC71 50%,transparent 100%);-fx-opacity:0.5;"/>

        <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" styleClass="scroll-pane">
            <VBox styleClass="home-content" spacing="22">

                <VBox spacing="2">
                    <Label text="Journal d'activité" styleClass="section-title"/>
                    <Label text="Historique complet des actions effectuées par les utilisateurs"
                           styleClass="section-subtitle"/>
                </VBox>

                <!-- KPI -->
                <HBox spacing="16">
                    <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS" spacing="0">
                        <HBox alignment="CENTER_LEFT" spacing="0">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <Label text="J" styleClass="kpi-badge-green"/>
                                    <Label text="TOTAL ACTIONS" styleClass="kpi-label"/>
                                </HBox>
                                <Label fx:id="totalLogs" text="0" styleClass="kpi-value, kpi-value-green"/>
                                <Label text="entrées dans le journal" styleClass="kpi-evolution"/>
                            </VBox>
                            <StackPane styleClass="kpi-icon-box, kpi-icon-box-green">
                                <Label text=" " styleClass="kpi-icon"/>
                            </StackPane>
                        </HBox>
                        <Region prefHeight="14"/>
                        <Region styleClass="kpi-bar-green" maxWidth="56"/>
                    </VBox>
                    <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS" spacing="0">
                        <HBox alignment="CENTER_LEFT" spacing="0">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <Label text="C" styleClass="kpi-badge-purple"/>
                                    <Label text="CONNEXIONS" styleClass="kpi-label"/>
                                </HBox>
                                <Label fx:id="totalConnexions" text="0" styleClass="kpi-value"/>
                                <Label text="sessions ouvertes" styleClass="kpi-evolution"/>
                            </VBox>
                            <StackPane styleClass="kpi-icon-box" style="-fx-background-color:#EAE8FF;">
                                <Label text=" " styleClass="kpi-icon"/>
                            </StackPane>
                        </HBox>
                        <Region prefHeight="14"/>
                        <Region style="-fx-background-color:#6C63FF;-fx-background-radius:2;-fx-pref-height:3;" maxWidth="56"/>
                    </VBox>
                    <VBox styleClass="kpi-card-purple" HBox.hgrow="ALWAYS" spacing="0">
                        <HBox alignment="CENTER_LEFT" spacing="0">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <Label text="T" styleClass="kpi-badge-white"/>
                                    <Label text="TRANSACTIONS" styleClass="kpi-label-white"/>
                                </HBox>
                                <Label fx:id="totalTransactions" text="0" styleClass="kpi-value, kpi-value-white"/>
                                <Label text="opérations financières" styleClass="kpi-evolution-white"/>
                            </VBox>
                            <StackPane styleClass="kpi-icon-box, kpi-icon-box-purple">
                                <Label text=" " styleClass="kpi-icon"/>
                            </StackPane>
                        </HBox>
                        <Region prefHeight="14"/>
                        <Region styleClass="kpi-bar-white" maxWidth="56"/>
                    </VBox>
                    <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS" spacing="0">
                        <HBox alignment="CENTER_LEFT" spacing="0">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <HBox spacing="8" alignment="CENTER_LEFT">
                                    <Label text="I" styleClass="kpi-badge-red"/>
                                    <Label text="INSCRIPTIONS" styleClass="kpi-label"/>
                                </HBox>
                                <Label fx:id="totalInscriptions" text="0" styleClass="kpi-value, kpi-value-red"/>
                                <Label text="nouveaux comptes créés" styleClass="kpi-evolution"/>
                            </VBox>
                            <StackPane styleClass="kpi-icon-box, kpi-icon-box-red">
                                <Label text=" " styleClass="kpi-icon"/>
                            </StackPane>
                        </HBox>
                        <Region prefHeight="14"/>
                        <Region styleClass="kpi-bar-red" maxWidth="56"/>
                    </VBox>
                </HBox>

                <!-- FILTRES -->
                <VBox styleClass="table-card" spacing="0">
                    <HBox styleClass="table-header-zone" alignment="CENTER_LEFT">
                        <Label text="Filtrer le journal" styleClass="section-title" style="-fx-padding:0 12 0 0;" HBox.hgrow="ALWAYS"/>
                        <Button text="✕ Réinitialiser" styleClass="btn-voir-tout"
                                style="-fx-font-size:11px;-fx-padding:5 12;" onAction="#resetFiltres"/>
                    </HBox>
                    <Separator style="-fx-opacity:0.4;"/>
                    <HBox style="-fx-padding:12 18;" spacing="10" alignment="CENTER_LEFT">
                        <HBox alignment="CENTER_LEFT" spacing="0"
                              style="-fx-background-color:#F7FAFC;-fx-border-color:#E2E8F0;-fx-border-radius:8;-fx-background-radius:8;">
                            <Label text=" 🔍 " style="-fx-font-size:12px;-fx-text-fill:#94A3B8;"/>
                            <TextField fx:id="searchField" promptText="Utilisateur, action, détails..."
                                       style="-fx-background-color:transparent;-fx-border-color:transparent;-fx-padding:7 10 7 0;-fx-font-size:12px;"
                                       prefWidth="240" onKeyReleased="#onSearchChanged"/>
                        </HBox>
                        <ComboBox fx:id="filterAction" promptText="Type d'action"
                                  style="-fx-background-color:#F7FAFC;-fx-border-color:#E2E8F0;-fx-border-radius:8;-fx-background-radius:8;-fx-font-size:12px;"
                                  prefWidth="190" onAction="#onFilterChanged"/>
                        <DatePicker fx:id="filterDateDebut" promptText="Date début"
                                    style="-fx-background-color:#F7FAFC;-fx-border-color:#E2E8F0;-fx-border-radius:8;-fx-background-radius:8;-fx-font-size:12px;"
                                    onAction="#onFilterChanged"/>
                        <DatePicker fx:id="filterDateFin" promptText="Date fin"
                                    style="-fx-background-color:#F7FAFC;-fx-border-color:#E2E8F0;-fx-border-radius:8;-fx-background-radius:8;-fx-font-size:12px;"
                                    onAction="#onFilterChanged"/>
                    </HBox>
                </VBox>

                <!-- TABLE -->
                <VBox styleClass="table-card" spacing="0">
                    <HBox styleClass="table-header-zone" alignment="CENTER_LEFT">
                        <VBox HBox.hgrow="ALWAYS" spacing="2">
                            <Label text="Historique des actions" styleClass="section-title"/>
                            <Label fx:id="countLabel" text="0 action(s)" styleClass="section-subtitle"/>
                        </VBox>
                    </HBox>
                    <Separator style="-fx-opacity:0.5;"/>

                    <TableView fx:id="logsTable"
                               styleClass="table-view"
                               prefHeight="440"
                               VBox.vgrow="ALWAYS"
                               style="-fx-background-color:transparent;
                                      -fx-border-color:transparent;
                                      -fx-table-cell-border-color:transparent;">
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                        <columns>
                            <TableColumn fx:id="colId"          text="ID"           minWidth="55"  maxWidth="65"/>
                            <TableColumn fx:id="colUtilisateur" text="UTILISATEUR"  minWidth="160"/>
                            <TableColumn fx:id="colAction"      text="ACTION"       minWidth="150" maxWidth="200"/>
                            <TableColumn fx:id="colDetails"     text="DÉTAILS"      minWidth="200"/>
                            <TableColumn fx:id="colDate"        text="DATE"         minWidth="145" maxWidth="165"/>
                            <TableColumn fx:id="colIp"          text="IP"           minWidth="110" maxWidth="130"/>
                        </columns>
                        <placeholder>
                            <VBox alignment="CENTER" spacing="8" style="-fx-padding:50;">
                                <Label text="📋" style="-fx-font-size:36px;"/>
                                <Label text="Aucune entrée dans le journal"
                                       style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#64748B;"/>
                                <Label text="Modifiez les filtres ou la période de recherche."
                                       style="-fx-font-size:12px;-fx-text-fill:#94A3B8;"/>
                            </VBox>
                        </placeholder>
                    </TableView>

                    <!-- PAGINATION -->
                    <HBox alignment="CENTER" spacing="8"
                          style="-fx-padding:10 18;-fx-background-color:#FAFBFF;
                                 -fx-border-color:#F0F0F0 transparent transparent transparent;">
                        <Label fx:id="paginationInfo" text=""
                               style="-fx-font-size:11px;-fx-text-fill:#718096;" HBox.hgrow="ALWAYS"/>
                        <HBox spacing="5" alignment="CENTER">
                            <Button fx:id="btnPremierePage" text="«" onAction="#goToPremierePage"
                                    styleClass="btn-voir-tout" style="-fx-min-width:32px;-fx-font-weight:bold;"/>
                            <Button fx:id="btnPagePrev" text="‹ Préc." onAction="#goToPagePrecedente" styleClass="btn-voir-tout"/>
                            <HBox fx:id="pageNumbersBox" spacing="4" alignment="CENTER"/>
                            <Button fx:id="btnPageNext" text="Suiv. ›" onAction="#goToPageSuivante" styleClass="btn-voir-tout"/>
                            <Button fx:id="btnDernierePage" text="»" onAction="#goToDernierePage"
                                    styleClass="btn-voir-tout" style="-fx-min-width:32px;-fx-font-weight:bold;"/>
                        </HBox>
                        <HBox spacing="6" alignment="CENTER_RIGHT" HBox.hgrow="ALWAYS">
                            <Label text="Par page :" style="-fx-font-size:11px;-fx-text-fill:#718096;"/>
                            <ComboBox fx:id="pageSizeCombo" prefWidth="65" onAction="#onPageSizeChanged"
                                      style="-fx-background-color:#F7FAFC;-fx-border-color:#E2E8F0;-fx-border-radius:8;-fx-background-radius:8;-fx-font-size:12px;"/>
                        </HBox>
                    </HBox>
                </VBox>

            </VBox>
        </ScrollPane>
    </VBox>
</HBox>